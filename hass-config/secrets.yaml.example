# Copy to secrets.yaml (which is gitignored) and fill in real values.
#
# MessageBird REST API Authorization header — literally "AccessKey <key>".
messagebird_auth: "AccessKey REPLACE_WITH_MESSAGEBIRD_ACCESS_KEY"

# Recipient phone number in international format, e.g. "+3816xxxxxxx".
alarm_phone_1: "+381600000000"

# Full message bodies. Put the current public alarm URL directly in the text
# (the old http://212.200.76.10:26681 link is stale — replace it).
alarm_message: "Detektovano je kretanje u kuci na Zlatiboru dok je alarm ukljucen! Proverite: http://REPLACE-WITH-PUBLIC-URL/lovelace/alarm"
alarm_reminder_message: "Nije bilo pomeranja u kuci na Zlatiboru vise od 48 sati, a alarm je iskljucen. Molimo ukljucite alarm: http://REPLACE-WITH-PUBLIC-URL/lovelace/alarm"
