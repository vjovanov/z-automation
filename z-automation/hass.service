[Unit]
Description=Home Assistant
After=network-online.target

[Service]
Type=simple
User=homeassistant
WorkingDirectory=/home/homeassistant/.homeassistant
ExecStart=/srv/homeassistant/bin/hass -v --config /home/homeassistant/.homeassistant --open-ui
Restart=on-failure
RestartSec=5s

# Logging
StandardOutput=file:/home/homeassistant/.homeassistant/home-assistant.log
StandardError=file:/home/homeassistant/.homeassistant/home-assistant.log

[Install]
WantedBy=multi-user.target
